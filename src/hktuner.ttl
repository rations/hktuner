@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix uihk:  <https://github.com/rations/LV2-haiku/ns/ui-haiku#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix work:  <http://lv2plug.in/ns/ext/worker#> .

<https://github.com/rations/hktuner#ui>
	a uihk:HaikuUI ;
	ui:binary <hktuner_ui.so> .

<https://github.com/rations/hktuner>
	a lv2:Plugin ,
		lv2:AnalyserPlugin ;
	doap:name "hktuner Chromatic Tuner" ;
	doap:license <http://opensource.org/licenses/MIT> ;
	lv2:optionalFeature lv2:hardRTCapable ,
		work:schedule ;
	lv2:extensionData work:interface ;
	ui:ui <https://github.com/rations/hktuner#ui> ;
	lv2:port [
		a lv2:InputPort ,
			lv2:ControlPort ;
		lv2:index 0 ;
		lv2:symbol "ref_freq" ;
		lv2:name "Reference A4" ;
		lv2:default 440.0 ;
		lv2:minimum 380.0 ;
		lv2:maximum 500.0 ;
		units:unit units:hz
	] , [
		a lv2:OutputPort ,
			lv2:ControlPort ;
		lv2:index 1 ;
		lv2:symbol "freq" ;
		lv2:name "Detected Frequency" ;
		lv2:minimum 0.0 ;
		lv2:maximum 1000.0 ;
		units:unit units:hz
	] , [
		a lv2:OutputPort ,
			lv2:ControlPort ;
		lv2:index 2 ;
		lv2:symbol "clarity" ;
		lv2:name "Clarity" ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		units:unit units:coef
	] , [
		a lv2:AudioPort ,
			lv2:InputPort ;
		lv2:index 3 ;
		lv2:symbol "in_l" ;
		lv2:name "In Left"
	] , [
		a lv2:AudioPort ,
			lv2:InputPort ;
		lv2:index 4 ;
		lv2:symbol "in_r" ;
		lv2:name "In Right"
	] , [
		a lv2:AudioPort ,
			lv2:OutputPort ;
		lv2:index 5 ;
		lv2:symbol "out_l" ;
		lv2:name "Out Left"
	] , [
		a lv2:AudioPort ,
			lv2:OutputPort ;
		lv2:index 6 ;
		lv2:symbol "out_r" ;
		lv2:name "Out Right"
	] .
