# Style for all code in this repo. Matches the sibling Haiku audio projects:
# 4-space indentation, Linux braces (function brace on its own line, control
# braces attached), no tabs.
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
BreakBeforeBraces: Linux
PointerAlignment: Right
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
SortIncludes: false
IndentCaseLabels: true
AccessModifierOffset: -4
